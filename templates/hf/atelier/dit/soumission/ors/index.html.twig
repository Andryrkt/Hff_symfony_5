{% extends "base.html.twig" %}

{% block title %}
	Soumission OR
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		object,
		embed {
			width: 100%;
			height: 750px;
			border: 1px solid #dee2e6;
			border-radius: 4px;
		}
	</style>
{% endblock %}


{% block content %}
	<div class="container-fluid mt-4 mb-4" {{ stimulus_controller('pages--hf--atelier--dit--soumission-ors') }} data-pages--hf--atelier--dit--soumission-ors-common--pdf-preview-outlet="#pdf-preview-container">
		<div class="row">
			<div class="col-12 col-lg-5">
				<div class="card shadow-sm">
					<div class="card-header bg-dark text-white">
						<h5 class="card-title mb-0">
							<i class="fas fa-file-upload me-2"></i>Soumission de l'OR
						</h5>
					</div>
					<div class="card-body">
						{{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
						{{ form_errors(form)}}

						<div class="row">
							<div class="col-6">
								{{ form_row(form.numeroDit)}}
							</div>
							<div class="col-6">
								{{ form_row(form.numeroOr)}}
							</div>
						</div>

						<hr>

						<div class="row">
							<div class="col-6 mb-3">
								<label class="form-label fw-bold">1. Veuillez insérer
									<strong>l\'OR à valider *</strong>
								</label>
								<div id="dropzone-1" {{ stimulus_controller('common--dropzone', { 'id-suffix': '1', 'expected-prefix': 'Ordre de réparation_' ~ form.vars.value.numeroOr|default(''), 'expected-keywords': (form.vars.value.numeroDit|default('') ~ ',' ~ form.vars.value.numeroOr|default(''))|trim(',') } ) }} data-action="
																													common--dropzone:fileSelected->pages--hf--atelier--dit--soumission-ors#onDropzoneFileSelected
																													common--dropzone:fileRemoved->pages--hf--atelier--dit--soumission-ors#onDropzoneFileRemoved
																												">
									{% include "partials/_dropZoneFile.html.twig" with {'id': '1', 'form': form, 'fieldName': 'pieceJoint01', 'fileType': 'PDF'} %}
								</div>
							</div>
							<div class="col-6 mb-3">
								<label class="form-label small fw-bold">2. Veuillez insérer
									<strong>le devis à fusionner</strong>avec l\'OR</label>
								<div id="dropzone-2" {{ stimulus_controller('common--dropzone', { 'id-suffix': '2' } ) }} data-action="
																													common--dropzone:fileSelected->pages--hf--atelier--dit--soumission-ors#onDropzoneFileSelected
																													common--dropzone:fileRemoved->pages--hf--atelier--dit--soumission-ors#onDropzoneFileRemoved
																												">
									{% include "partials/_dropZoneFile.html.twig" with {'id': '2', 'form': form, 'fieldName': 'pieceJoint02', 'fileType': 'PDF'} %}
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-6 mb-3">
								<label class="form-label small fw-bold">3. Veuillez insérer
									<strong>le BC ou autre document à fusionner</strong>avec l\'OR (si existant)</label>
								<div id="dropzone-3" {{ stimulus_controller('common--dropzone', { 'id-suffix': '3' } ) }} data-action="
																													common--dropzone:fileSelected->pages--hf--atelier--dit--soumission-ors#onDropzoneFileSelected
																													common--dropzone:fileRemoved->pages--hf--atelier--dit--soumission-ors#onDropzoneFileRemoved
																												">
									{% include "partials/_dropZoneFile.html.twig" with {'id': '3', 'form': form, 'fieldName': 'pieceJoint03', 'fileType': 'PDF'} %}
								</div>
							</div>
							<div class="col-6 mb-3">
								<label class="form-label small fw-bold">4. Veuillez insérer
									<strong>les documents à fusionner</strong>avec l\'OR (si existant)</label>
								<div id="dropzone-4" {{ stimulus_controller('common--dropzone', { 'id-suffix': '4', 'multiple': true } ) }} data-action="
																													common--dropzone:filesSelected->pages--hf--atelier--dit--soumission-ors#onDropzoneFilesSelected
																													common--dropzone:fileRemoved->pages--hf--atelier--dit--soumission-ors#onDropzoneFileRemoved
																												">
									{% include "partials/_dropZoneFileMultiple.html.twig" with {'id': '4', 'form': form, 'fieldName': 'pieceJoint04'} %}
								</div>
							</div>
						</div>

						<div class="mb-3">
							{{ form_row(form.observation)}}
						</div>

						<div class="d-grid gap-2">
							{% import "macros/actions.html.twig" as actions %}
							{{ actions.submit_button(
								'Enregistrer et Envoyer dans Docuware',
								'fas fa-paper-plane',
								'btn-warning',
								true,
								'Confirmez-vous la soumission ?',
								'Le processus peut prendre quelques instants.',
								'Soumission OR'
							) }}
							<a href="{{ path('hf_atelier_dit_liste_index') }}" class="btn btn-outline-secondary">
								<i class="fas fa-arrow-left me-1"></i>Retour à la liste
							</a>
						</div>
						{{ form_end(form) }}
					</div>
				</div>
			</div>

			<div class="col-12 col-lg-7" id="pdf-preview-container" {{ stimulus_controller('common--pdf-preview') }}>
				<div id="pdf-preview-zone" class="card shadow-sm h-100 d-none" data-common--pdf-preview-target="pdfPreview">
					<div class="card-header bg-info text-white pb-0 border-bottom-0">
						<div class="d-flex align-items-center mb-2 mt-1">
							<i class="fas fa-eye me-2"></i>
							<h5 class="card-title mb-0">Aperçu des documents</h5>
						</div>
						<ul
							class="nav nav-tabs card-header-tabs m-0 border-0" data-common--pdf-preview-target="navTabs"><!-- Onglets injectés via JS -->
						</ul>
					</div>
					<div
						class="card-body p-0 tab-content bg-white border-top border-info border-3" data-common--pdf-preview-target="tabContent"><!-- Contenu des onglets injecté via JS -->
					</div>
				</div>
				<div class="h-100 d-flex align-items-center justify-content-center bg-light border rounded" data-common--pdf-preview-target="placeholder">
					<div class="text-center text-muted p-5">
						<i class="fas fa-file-pdf fa-4x mb-3"></i>
						<p>Sélectionnez au moins un fichier pour afficher l'aperçu.</p>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
